{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "coach-verdict-v1",
  "title": "Coach Review Verdict",
  "description": "Structured verdict output from Coach Step 2.5/3. Machine-consumed by Player.",
  "type": "object",
  "required": ["verdict", "project", "timestamp", "methodology", "findings", "tasks_generated"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["APPROVE", "FIX", "REVERT"],
      "description": "APPROVE: all checks pass. FIX: issues found, tasks generated. REVERT: last commit broken, must be reverted."
    },
    "project": {
      "type": "string",
      "description": "Project name (e.g. 'gto-wizard-clone', 'polytopia-clone')"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of this review"
    },
    "cycle_id": {
      "type": "string",
      "description": "Optional: cron run ID for traceability"
    },
    "reference_match": {
      "type": "string",
      "enum": ["exact", "minor_gaps", "significant_gaps", "broken", "not_checked"],
      "description": "How well the clone matches the reference original"
    },
    "checkpoint": {
      "type": "object",
      "description": "Checkpoint state before this review",
      "properties": {
        "current_task": {"type": "string"},
        "commit_sha": {"type": "string"},
        "last_coach_review": {"type": "string"}
      }
    },
    "methodology": {
      "type": "object",
      "required": ["total_failures", "test_bugs", "methodology_failures", "systemic", "can_approve"],
      "properties": {
        "total_failures": {"type": "integer"},
        "test_bugs": {"type": "integer", "description": "Technical failures: flaky timing, wrong API, coordinate errors"},
        "methodology_failures": {"type": "integer", "description": "Self-referential tests, implementation-validating tests"},
        "systemic": {"type": "boolean", "description": "True if same failure pattern across 3+ tests"},
        "can_approve": {"type": "boolean", "description": "False if >50% are methodology failures (blocks APPROVE)"}
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "type", "description"],
        "properties": {
          "severity": {"type": "string", "enum": ["P1", "P2", "P3"]},
          "type": {"type": "string", "enum": ["bug", "regression", "visual_gap", "methodology_gap", "perf", "security", "other"]},
          "area": {"type": "string", "description": "Component or feature area (e.g. 'study page', 'canvas render')"},
          "description": {"type": "string"},
          "evidence": {"type": "string", "description": "Screenshot path, console error, or specific behavior observed"},
          "test_attribution": {"type": "string", "description": "Which test caught this (refqa run id, Playwright spec name, or 'browser manual')"}
        }
      }
    },
    "tasks_generated": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": {"type": "string", "description": "Task identifier from AGENTS.md (e.g. 'fix-study-advance-turn')"},
          "description": {"type": "string"},
          "priority": {"type": "string", "enum": ["P1", "P2", "P3"]},
          "success_criteria": {"type": "string"}
        }
      },
      "description": "Tasks written to AGENTS.md during Step 4. Empty if APPROVE."
    },
    "errors": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Any errors during the review itself (subagent failures, browser crashes, etc.)"
    }
  }
}
